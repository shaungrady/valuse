{
	"name": "valuse",
	"version": "0.0.0",
	"description": "Reactive state that mirrors how you already think about data.",
	"type": "module",
	"license": "MIT",
	"sideEffects": [
		"./dist/react.mjs"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./react": {
			"types": "./dist/react.d.mts",
			"import": "./dist/react.mjs"
		},
		"./utils": {
			"types": "./dist/utils.d.mts",
			"import": "./dist/utils.mjs"
		},
		"./middleware": {
			"types": "./dist/middleware.d.mts",
			"import": "./dist/middleware.mjs"
		}
	},
	"files": [
		"README.md",
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"check": "prettier --experimental-ternaries --check . && eslint . && tsc --noEmit && vitest run && tsdown",
		"check:fix": "prettier --experimental-ternaries --write . && eslint --fix . && tsc --noEmit && vitest run && tsdown",
		"lint": "eslint --fix .",
		"format": "prettier --experimental-ternaries --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:types": "vitest --typecheck.only --run",
		"prepack": "pnpm build"
	},
	"dependencies": {
		"@preact/signals-core": "^1.14.1"
	},
	"peerDependencies": {
		"@standard-schema/spec": ">=1",
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"@standard-schema/spec": {
			"optional": true
		},
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@standard-schema/spec": "^1.1.0",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"@vitest/coverage-v8": "^4.1.4",
		"arktype": "^2.2.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^5.2.0",
		"expect-type": "^1.3.0",
		"fake-indexeddb": "^6.2.5",
		"jiti": "^2.6.1",
		"jsdom": "^26.1.0",
		"lefthook": "^2.1.4",
		"prettier": "^3.8.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tsdown": "^0.21.7",
		"type-fest": "^5.5.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"volta": {
		"node": "24.14.1"
	},
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lefthook"
		]
	}
}
